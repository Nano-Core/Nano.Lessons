{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    },
    "HealthCheck": {
      "UseHealthCheckUI": true,
      "EvaluationInterval": 10,
      "FailureNotificationInterval": 60,
      "MaximumHistoryEntriesPerEndpoint": 50,
      "WebHooks": [
        {
          "Name": "Test",
          "Url": "http://localhost:8080/api/examples/webhook",
          "Payload": null
        }
      ]
    }
  }
}