{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    },
    "HttpPolicyHeaders": {
      "Robots": {
        "UseNoIndex": true,
        "UseNoFollow": true,
        "UseNoSnippet": true,
        "UseNoArchive": true,
        "UseNoOdp": true,
        "UseNoTranslate": true,
        "UseNoImageIndex": true
      }
    }
  }
}