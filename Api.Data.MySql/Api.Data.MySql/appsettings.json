{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    }
  },
  "Data": {
    "BatchSize": 25,
    "BulkBatchSize": 500,
    "BulkBatchDelay": 1000,
    "QueryRetryCount": 0,
    "UseLazyLoading": false,
    "UseCreateDatabase": true,
    "UseMigrateDatabase": false,
    "UseSoftDeletetion": false,
    "UseSensitiveDataLogging": false,
    "UseAudit": false,
    "QuerySplittingBehavior": "SingleQuery",
    "DefaultCollation": null,
    "ConnectionString": null,
    "Repository": {
      "UseAutoSave": false,
      "QueryIncludeDepth": 4
    },
    "Cache": null,
    "Identity": null,
    "ConnectionPool": null,
    "HealthCheck": null
  }
}