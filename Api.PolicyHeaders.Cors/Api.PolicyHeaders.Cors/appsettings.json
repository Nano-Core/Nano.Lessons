{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    },
    "HttpPolicyHeaders": {
      "Cors": {
        "AllowedOrigins": [
          "http://localhost:8080"
        ],
        "AllowedHeaders": [
          "Content-Type"
        ],
        "AllowedMethods": [
          "GET",
          "POST"
        ],
        "AllowCredentials": false,
        "Origin": {
          "EmbedderPolicy": "UnsafeNone",
          "OpenerPolicy": "SameOriginAllowPopups",
          "ResourcePolicy": "SameOrigin"
        },
        "ExposedHeaders": [
        ]
      }
    }
  }
}