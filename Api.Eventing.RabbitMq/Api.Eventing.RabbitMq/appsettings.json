{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    },
    "HealthCheck": {
    }
  },
  "Eventing": {
    "Host": "rabbitmq",
    "VHost": "/",
    "Port": 5672,
    "UseSsl": false,
    "Timeout": "00:00:30",
    "Heartbeat": 60,
    "PrefetchCount": 50,
    "Credentials": {
      "Id": null,
      "Secret": null
    },
    "HealthCheck": {
      "UnhealthyStatus": "Unhealthy"
    }
  }
}