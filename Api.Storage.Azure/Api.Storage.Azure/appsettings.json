{
  "App": {
    "Version": "1.0.0.0",
    "Hosting": {
      "Root": "api",
      "Http": {
        "Ports": [
          8080
        ]
      }
    },
    "HealthCheck": {
      "EvaluationInterval": 10,
      "FailureNotificationInterval": 60,
      "MaximumHistoryEntriesPerEndpoint": 50
    }
  },
  "Storage": {
    "ShareName": "nano-storage-azure",
    "Credentials": {
      "Id": null,
      "Secret": null
    },
    "HealthCheck": {
      "UnhealthyStatus": "Degraded"
    }
  }
}